# ============================================================================
# Backup & Restore Configuration
# Copier ce fichier en .env et remplir avec vos valeurs
# NE PAS commiter .env (voir .gitignore)
# ============================================================================

# Logging
LOG_FILE=backup.log
LOG_LEVEL=INFO

# Restauration - Sécurité
RESTORE_VERIFY_HASH=true
RESTORE_TIMEOUT_SECONDS=3600

# Exclusions (séparées par virgule)
EXCLUDE_PATTERNS=.pyc,__pycache__,.git,node_modules,.env,*.swp

# Chemins optionnels (si vides, utilise répertoire courant)
BACKUP_OUTPUT_DIR=./backups
RESTORE_OUTPUT_DIR=./restored

# Performance
CHUNK_SIZE_BYTES=4096
MAX_CONCURRENT_EXTRACTIONS=4

# Disponibilité
KEEP_ARCHIVE_AFTER_ENCRYPT=false
KEEP_MANIFEST=true

# ISO 27001 Compliance
ISO27001_AUDIT_TRAIL=true
ISO27001_IMMUTABLE_LOG=true
ISO27001_PERMISSIONS_MODE=0o640
